# =============================================================================
# Velora — Environment Variables (template)
# =============================================================================
# Salin file ini ke `.env.local` lalu isi nilai sesuai environment Anda.
# JANGAN commit `.env.local` ke git (lihat `.gitignore`).
# Setiap nilai NEXT_PUBLIC_* akan ter-expose ke browser — JANGAN isi secret.
# =============================================================================


# -----------------------------------------------------------------------------
# Supabase — backend service
# -----------------------------------------------------------------------------
# URL project Supabase. Tanpa ini, aplikasi tidak akan bisa konek ke DB.
# Format: https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Anon (public) key dari Supabase dashboard (Project Settings → API).
# Key ini aman untuk di-expose ke browser karena dilindungi RLS.
NEXT_PUBLIC_SUPABASE_ANON_KEY=


# -----------------------------------------------------------------------------
# Public root domain — untuk subdomain rewrite di middleware.
# (lihat `middleware.ts`)
# -----------------------------------------------------------------------------
# Di production: domain utama Velora, mis. `velora.id` atau `velora.my.id`.
# Di development: `localhost:3000`.
NEXT_PUBLIC_ROOT_DOMAIN=localhost:3000


# -----------------------------------------------------------------------------
# Development mode — mock client untuk visual QA tanpa Supabase.
# -----------------------------------------------------------------------------
# Set ke "1" untuk mengaktifkan. Saat aktif, halaman `/i/<slug-apapun>`
# akan menggunakan data mock dari `lib/mock/*` dan bukan query ke DB.
# Berguna untuk preview tema 'Sana' sebelum klien punya data nyata.
# HAPUS / set ke "0" untuk production.
VELORA_USE_MOCK_CLIENT=1
