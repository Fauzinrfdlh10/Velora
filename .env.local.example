# ============================================================
# Velora — Environment Variables
# ============================================================
# Salin file ini ke .env.local dan isi dengan kredensial kamu.
#   cp .env.local.example .env.local
# ============================================================

# --- Supabase (wajib) ---
# URL project Supabase kamu. Format: https://<project-id>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public key. Didapatkan dari dashboard Supabase:
#   Settings → Data API → anon public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ============================================================
# Variabel di bawah ini akan ditambahkan di tahap berikutnya:
# ============================================================
# SUPABASE_SERVICE_ROLE_KEY=   (untuk operasi admin server-side)
# NEXT_PUBLIC_SITE_URL=        (untuk Vercel deployment)
